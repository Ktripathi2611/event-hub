# JWT_SECRET: Required by the API server for signing auth tokens.
JWT_SECRET="replace-with-a-long-random-secret"

# GEMINI_API_KEY: Optional. Do not expose a real key to the browser unless a browser-safe use case exists.
GEMINI_API_KEY=""

# APP_URL: Optional. Reserved for future absolute-URL features.
APP_URL="http://localhost:3000"

# DISABLE_HMR: Optional. Set to true to disable Vite hot module reload in development.
DISABLE_HMR="false"
